#!/usr/bin/env bash
#MISE description="Benchmark all integration tests: bash vs YAML side-by-side"
#MISE depends=["dev"]
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
export PATH="$REPO_ROOT/target/release:$PATH"

# Pre-build xtask in release mode (excluded from timing)
cargo build --package xtask --release --quiet

ms_now() {
    perl -MTime::HiRes=time -e 'printf "%d\n", time*1000'
}

# Commands to benchmark: <label> <bash_test_file> <yaml_scenario_dir>
SUITES=(
    "exec:test_exec.sh:exec"
    "clone:test_clone.sh:clone"
    "init:test_init.sh:init"
    "checkout:test_checkout.sh:checkout"
    "checkout-branch:test_checkout_branch.sh:checkout-branch"
    "prune:test_prune.sh:prune"
    "branch-delete:test_branch_delete.sh:branch-delete"
    "list:test_list.sh:list"
    "fetch:test_fetch.sh:fetch"
    "hooks:test_hooks.sh:hooks"
    "sync:test_sync.sh:sync"
    "config:test_config.sh:config"
    "completions:test_completions.sh:completions"
    "rename:test_rename.sh:rename"
    # shell-init and setup are not in test_all.sh (not run in CI),
    # so they have stale bash expectations. YAML-only benchmarks below.
)

# Collect results
declare -a labels
declare -a bash_times
declare -a bash_statuses
declare -a yaml_times
declare -a yaml_statuses

total_bash_ms=0
total_yaml_ms=0
any_failed=0

echo
echo "=== Integration Tests: Bash vs YAML Benchmark ==="
echo

overall_start=$(ms_now)

for suite in "${SUITES[@]}"; do
    IFS=':' read -r label bash_file yaml_dir <<< "$suite"
    labels+=("$label")

    echo "--- $label ---"
    echo

    # Bash
    echo "  Bash: $bash_file"
    bash_start=$(ms_now)
    bash_result=0
    (cd "$REPO_ROOT/tests/integration" && bash "./$bash_file") > /dev/null 2>&1 || bash_result=$?
    bash_end=$(ms_now)
    ms=$((bash_end - bash_start))
    bash_times+=("$ms")
    total_bash_ms=$((total_bash_ms + ms))

    if [ $bash_result -eq 0 ]; then
        bash_statuses+=("PASS")
        echo "  Bash: PASS (${ms}ms)"
    else
        bash_statuses+=("FAIL")
        echo "  Bash: FAIL (${ms}ms)"
        any_failed=1
    fi

    # YAML
    echo "  YAML: scenarios/$yaml_dir/"
    yaml_start=$(ms_now)
    yaml_result=0
    "$REPO_ROOT/target/release/xtask" manual-test --ci "$REPO_ROOT/tests/manual/scenarios/$yaml_dir/" > /dev/null 2>&1 || yaml_result=$?
    yaml_end=$(ms_now)
    ms=$((yaml_end - yaml_start))
    yaml_times+=("$ms")
    total_yaml_ms=$((total_yaml_ms + ms))

    if [ $yaml_result -eq 0 ]; then
        yaml_statuses+=("PASS")
        echo "  YAML: PASS (${ms}ms)"
    else
        yaml_statuses+=("FAIL")
        echo "  YAML: FAIL (${ms}ms)"
        any_failed=1
    fi

    echo
done

# YAML-only suites (bash tests not in test_all.sh / not run in CI)
YAML_ONLY_SUITES=(
    "shell-init"
    "setup"
)

for yaml_dir in "${YAML_ONLY_SUITES[@]}"; do
    labels+=("$yaml_dir")

    echo "--- $yaml_dir (YAML only) ---"
    echo

    bash_times+=("0")
    bash_statuses+=("--")

    echo "  YAML: scenarios/$yaml_dir/"
    yaml_start=$(ms_now)
    yaml_result=0
    "$REPO_ROOT/target/release/xtask" manual-test --ci "$REPO_ROOT/tests/manual/scenarios/$yaml_dir/" > /dev/null 2>&1 || yaml_result=$?
    yaml_end=$(ms_now)
    ms=$((yaml_end - yaml_start))
    yaml_times+=("$ms")
    total_yaml_ms=$((total_yaml_ms + ms))

    if [ $yaml_result -eq 0 ]; then
        yaml_statuses+=("PASS")
        echo "  YAML: PASS (${ms}ms)"
    else
        yaml_statuses+=("FAIL")
        echo "  YAML: FAIL (${ms}ms)"
        any_failed=1
    fi

    echo
done

overall_end=$(ms_now)
overall_ms=$((overall_end - overall_start))

# Summary table
echo "=========================================="
echo "  Summary"
echo "=========================================="
echo
printf "  %-20s  %-14s  %-14s\n" "Suite" "Bash" "YAML"
printf "  %-20s  %-14s  %-14s\n" "-----" "----" "----"

for i in "${!labels[@]}"; do
    bash_cell="${bash_statuses[$i]}  ${bash_times[$i]}ms"
    yaml_cell="${yaml_statuses[$i]}  ${yaml_times[$i]}ms"
    if [ "${bash_statuses[$i]}" = "--" ]; then
        bash_cell="--"
    fi
    printf "  %-20s  %-14s  %-14s\n" "${labels[$i]}" "$bash_cell" "$yaml_cell"
done

printf "  %-20s  %-14s  %-14s\n" "-----" "----" "----"
printf "  %-20s  %-14s  %-14s\n" "TOTAL" "${total_bash_ms}ms" "${total_yaml_ms}ms"
echo
printf "  Wall time: %dms (%.1fs)\n" "$overall_ms" "$(echo "scale=1; $overall_ms/1000" | bc)"
echo

if [ $any_failed -ne 0 ]; then
    echo "  WARNING: One or more suites failed"
    exit 1
fi
