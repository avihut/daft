#!/usr/bin/env bash
#MISE description="Remove the sandbox for this worktree (graceful — runs clean-repos first)"
set -euo pipefail

usage() {
    cat <<'EOF'
Usage: mise run sandbox:clean [--trust-hooks] [--force] [--no-hooks]

Remove the sandbox for the current worktree.

By default, runs sandbox:clean-repos first so daft fires
worktree-pre-remove and worktree-post-remove hooks for every test repo.
Hooks let trusted repos tear down external state (docker containers,
databases, direnv allow lists, background jobs) before the sandbox dir is
wiped — bare `rm -rf $sandbox` cannot.

Halts before `rm -rf` if clean-repos detects a problem (untrusted hook-
defining repo, or a hook failure). The sandbox is left in place for
triage. Use the override flags below to proceed anyway.

Options:
  --trust-hooks   Pre-grant trust to any hook-defining repos that aren't
                  trusted, so their cleanup hooks fire. Trust grants live
                  in the per-worktree sandbox trust DB and disappear with
                  the sandbox itself, so the security blast radius is
                  exactly the duration of this command.
  --force         Continue past clean-repos failures and wipe the sandbox
                  regardless. External resources may leak.
  --no-hooks      Skip clean-repos entirely. Use when clean-repos itself
                  is broken or the sandbox is already in an unrecoverable
                  state.
  -h, --help      Show this help.
EOF
}

trust_hooks=false
force=false
run_hooks=true
for arg in "$@"; do
    case "$arg" in
        --trust-hooks)  trust_hooks=true ;;
        --force)        force=true ;;
        --no-hooks)     run_hooks=false ;;
        -h|--help)      usage; exit 0 ;;
        *)              echo "Unknown argument: $arg" >&2; usage >&2; exit 2 ;;
    esac
done

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/_lib.sh"

sandbox_dir="$(sandbox_dir)"

if [ ! -d "$sandbox_dir" ]; then
    echo "No sandbox found for this worktree"
    exit 0
fi

# --- Graceful per-repo cleanup so hooks fire ---
if $run_hooks; then
    clean_repos_args=()
    $trust_hooks && clean_repos_args+=("--trust-hooks")
    $force       && clean_repos_args+=("--force")

    echo "Running clean-repos so worktree-pre/post-remove hooks fire..."
    if ! "${SCRIPT_DIR}/clean-repos" "${clean_repos_args[@]}"; then
        if $force; then
            # User explicitly asked to wipe regardless. clean-repos already
            # printed which repo(s) failed and why; we just acknowledge and
            # proceed to the rm -rf below.
            echo ""
            echo "clean-repos had failures — wiping anyway because --force."
        else
            # clean-repos already explained why and printed override hints.
            # Silently wiping after a halt would defeat the whole point of
            # running clean-repos first.
            echo ""
            echo "clean-repos exited non-zero — sandbox NOT wiped. See message above."
            echo "Re-run with --force to wipe anyway, or --no-hooks to skip clean-repos."
            exit 1
        fi
    fi
fi

# --- Remove the sandbox dir ---
rm -rf "$sandbox_dir"
echo "Removed sandbox at ${sandbox_dir}"
