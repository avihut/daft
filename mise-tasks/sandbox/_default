chmod +x "${bin_dir}/show-test"

cat > "${bin_dir}/reset-test" <<'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail
sandbox_dir="$(dirname "$(dirname "$(realpath "$0")")")"
test_base="${sandbox_dir}/test"

# Determine which test to reset.
if [[ $# -gt 0 ]]; then
    slug="$(echo "$1" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"
    test_dir="${test_base}/${slug}"
else
    # Default to the only test, or error if multiple.
    dirs=("$test_base"/*)
    dirs=("${dirs[@]/#/}") # expand
    count=0
    for d in "$test_base"/*/; do
        [[ -d "$d" ]] && count=$((count + 1)) && test_dir="${d%/}"
    done
    if [[ $count -eq 0 ]]; then
        echo "No test environments found in ${test_base}/" >&2
        exit 1
    elif [[ $count -gt 1 ]]; then
        echo "Multiple test environments found. Specify one:" >&2
        for d in "$test_base"/*/; do
            echo "  $(basename "${d%/}")" >&2
        done
        exit 1
    fi
fi

if [[ ! -d "$test_dir" ]]; then
    echo "Test environment not found: $test_dir" >&2
    exit 1
fi

# Reset: clear work/, restore remotes from template.
rm -rf "${test_dir}/work"
mkdir -p "${test_dir}/work"
if [[ -d "${test_dir}/remotes-template" ]]; then
    rm -rf "${test_dir}/remotes"
    cp -a "${test_dir}/remotes-template" "${test_dir}/remotes"
fi
echo "Reset test environment: $(basename "$test_dir")"
SCRIPT
chmod +x "${bin_dir}/reset-test"

cat > "${bin_dir}/help" <<SCRIPT
