#!/usr/bin/env bash
#MISE description="Create or enter a per-worktree test sandbox"
set -euo pipefail

# --- Configuration (override via env vars) ---
DAFT_SANDBOX_GIT_NAME="${DAFT_SANDBOX_GIT_NAME:-Daft Developer}"
DAFT_SANDBOX_GIT_EMAIL="${DAFT_SANDBOX_GIT_EMAIL:-dev@daft.test}"

# --- Compute deterministic sandbox path ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/_lib.sh"

sandbox_dir="$(sandbox_dir)"
bin_dir="${sandbox_dir}/bin"
# pwd returns the project root because mise always runs tasks from there
worktree_path="$(pwd)"
bat_path="$(mise which bat)"

# --- Warn if release binary hasn't been built yet ---
if [ ! -d "${worktree_path}/target/release" ]; then
    echo "Warning: target/release not found — run 'mise run dev' first" >&2
fi

# --- Create sandbox directory if needed ---
if [ -d "$sandbox_dir" ]; then
    sandbox_verb="Updated"
else
    mkdir -p "$sandbox_dir"
    sandbox_verb="Created"
fi

mkdir -p "${sandbox_dir}/config"
mkdir -p "${bin_dir}/completions"

# --- Always (re)generate .envrc to pick up config changes ---
cat > "${sandbox_dir}/.envrc" <<ENVRC
# Daft development sandbox
# Generated by: mise run sandbox
# Worktree: ${worktree_path}

export DAFT_WORKTREE="${worktree_path}"
export DAFT_CONFIG_DIR="${sandbox_dir}/config"
export DAFT_NO_UPDATE_CHECK=1
export DAFT_NO_TRUST_PRUNE=1
export PATH="${bin_dir}:\${DAFT_WORKTREE}/target/release:\$PATH"

export GIT_AUTHOR_NAME="${DAFT_SANDBOX_GIT_NAME}"
export GIT_AUTHOR_EMAIL="${DAFT_SANDBOX_GIT_EMAIL}"
export GIT_COMMITTER_NAME="${DAFT_SANDBOX_GIT_NAME}"
export GIT_COMMITTER_EMAIL="${DAFT_SANDBOX_GIT_EMAIL}"

# Completions: direnv exports this env var, source enable-completions to load them
export DAFT_SANDBOX_COMPLETIONS_DIR="${bin_dir}/completions"
ENVRC

# --- Write helper scripts ---
cat > "${bin_dir}/rebuild-daft" <<'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail
(cd "$DAFT_WORKTREE" && mise run dev)
SCRIPT
chmod +x "${bin_dir}/rebuild-daft"

cat > "${bin_dir}/go-to-worktree" <<'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail
cd "$DAFT_WORKTREE"
exec "$SHELL"
SCRIPT
chmod +x "${bin_dir}/go-to-worktree"

cat > "${bin_dir}/clean-sandbox" <<'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail
worktree="$DAFT_WORKTREE"
(cd "$worktree" && mise run sandbox:clean)
cd "$worktree"
exec "$SHELL"
SCRIPT
chmod +x "${bin_dir}/clean-sandbox"

cat > "${bin_dir}/manual-test" <<'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail
(cd "$DAFT_WORKTREE" && cargo run --package xtask -- manual-test "$@")
SCRIPT
chmod +x "${bin_dir}/manual-test"

cat > "${bin_dir}/help" <<SCRIPT
#!/usr/bin/env bash
set -euo pipefail
${bat_path} "\$(dirname "\$(dirname "\$(realpath "\$0")")")/README.md" -p
SCRIPT
chmod +x "${bin_dir}/help"

# --- Completions for helper scripts ---
cat > "${bin_dir}/completions/_manual-test" <<'ZSH_COMP'
#compdef manual-test

_manual-test() {
    local -a scenarios
    local scenarios_dir="${DAFT_WORKTREE}/tests/manual/scenarios"

    if [[ -d "$scenarios_dir" ]]; then
        local f rel
        for f in "$scenarios_dir"/**/*.yml "$scenarios_dir"/**/*.yaml(N); do
            rel="${f#$scenarios_dir/}"
            if [[ "$rel" == */* ]]; then
                # Subdirectory: exec/checkout-single.yml → exec:checkout-single
                scenarios+=("${rel%%/*}:${${rel#*/}:r}")
            else
                scenarios+=("${rel:r}")
            fi
        done
    fi

    _arguments -s \
        '--ci[Run in non-interactive mode]' \
        '--no-interactive[Run in non-interactive mode]' \
        {-v,--verbose}'[Show verbose output]' \
        '--step[Jump to a specific step number]:step number:' \
        '--loop-count[Re-run a specific step N times]:count:' \
        '--keep[Keep test environment after completion]' \
        '--list[List available scenarios and exit]' \
        '*:scenario:($scenarios)'
}
ZSH_COMP

cat > "${bin_dir}/completions/manual-test.bash" <<'BASH_COMP'
_manual_test() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    if [[ "$cur" == -* ]]; then
        COMPREPLY=($(compgen -W "--ci --no-interactive -v --verbose --step --loop-count --keep --list" -- "$cur"))
        return
    fi
    local scenarios_dir="${DAFT_WORKTREE}/tests/manual/scenarios"
    if [[ -d "$scenarios_dir" ]]; then
        local scenarios="" f rel name
        while IFS= read -r -d '' f; do
            rel="${f#$scenarios_dir/}"
            name="${rel%.yml}"
            name="${name%.yaml}"
            if [[ "$name" == */* ]]; then
                # Subdirectory: exec/checkout-single → exec:checkout-single
                name="${name%%/*}:${name#*/}"
            fi
            scenarios="$scenarios $name"
        done < <(find "$scenarios_dir" \( -name '*.yml' -o -name '*.yaml' \) -print0 2>/dev/null)
        COMPREPLY=($(compgen -W "$scenarios" -- "$cur"))
    fi
}
complete -F _manual_test manual-test
BASH_COMP

# --- Sourceable completion loader ---
cat > "${bin_dir}/enable-completions" <<'LOADER'
# Source this file to enable tab completions for sandbox helpers.
# Usage: source enable-completions
if [[ -n "${ZSH_VERSION:-}" ]]; then
    source "${DAFT_SANDBOX_COMPLETIONS_DIR}/_manual-test"
    compdef _manual-test manual-test
elif [[ -n "${BASH_VERSION:-}" ]]; then
    source "${DAFT_SANDBOX_COMPLETIONS_DIR}/manual-test.bash"
fi
LOADER

# --- README ---
cat > "${sandbox_dir}/README.md" <<'README'
# Daft Dev Sandbox

## First things first

Load completions for sandbox helpers and the daft dev binary:

    source enable-completions
    eval "$(daft shell-init $(basename "$SHELL"))"

## Available commands

    help                     Show this guide
    manual-test <scenario>   Run a manual test scenario interactively
    manual-test --list       List available scenarios
    rebuild-daft             Rebuild daft and update symlinks
    go-to-worktree           Open a shell in the worktree directory
    clean-sandbox            Remove this sandbox and return to the worktree

## Tips

- Tab-complete scenario names and flags after running `source enable-completions`
- Run `rebuild-daft` after making code changes to pick them up
- Run `manual-test --keep <scenario>` to keep the test environment for inspection
- The sandbox has an isolated git identity and config directory
README

# --- Quick hint file ---
touch "${sandbox_dir}/run-help"

# Allow direnv if available
if command -v direnv &>/dev/null; then
    direnv allow "$sandbox_dir"
fi

echo "${sandbox_verb} sandbox at ${sandbox_dir}"
echo "  Tab completions: run 'source enable-completions' once per shell session"

# --- CD via DAFT_CD_FILE (same mechanism as daft commands) ---
if [ -n "${DAFT_CD_FILE:-}" ]; then
    echo "$sandbox_dir" > "$DAFT_CD_FILE"
fi
