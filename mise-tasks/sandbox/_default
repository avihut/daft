cat > "${bin_dir}/setup-test" <<'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail

# Parse args: setup-test <scenario> [--step N]
scenario=""
step_arg=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --step) step_arg="--step $2"; shift 2 ;;
        *) scenario="$1"; shift ;;
    esac
done

if [[ -z "$scenario" ]]; then
    echo "Usage: setup-test <scenario> [--step N]" >&2
    exit 1
fi

sandbox_dir="$(dirname "$(dirname "$(realpath "$0")")")"
test_base="${sandbox_dir}/test"
mkdir -p "$test_base"
export DAFT_MANUAL_TEST_BASE="$test_base"
# xtask prints the work dir path to stdout; stderr has the progress output.
# shellcheck disable=SC2086
work_dir=$(cd "$DAFT_WORKTREE" && cargo run --package xtask -- manual-test --setup-only $step_arg "$scenario")
if [[ -n "$work_dir" && -d "$work_dir" ]]; then
    cd "$work_dir" || true
    echo "You are now in: $work_dir"
    # Start a new shell with the sandbox environment, completions, and daft
    # shell integration pre-loaded. Plain `exec $SHELL` would lose everything
    # from `source init` and the direnv-loaded .envrc (PATH, DAFT_WORKTREE, etc.)
    # because the new shell's startup scripts reset PATH and direnv won't fire
    # outside the sandbox directory.
    envrc="${sandbox_dir}/.envrc"
    init_script="${sandbox_dir}/bin/init"
    if [[ "$SHELL" == *zsh* ]]; then
        _zdir=$(mktemp -d)
        [[ -f "$HOME/.zshenv" ]] && ln -s "$HOME/.zshenv" "${_zdir}/.zshenv"
        cat > "${_zdir}/.zshrc" <<ZSHRC
# Reset ZDOTDIR so subsequent shells use normal config
ZDOTDIR="\$HOME"
[[ -f "\$HOME/.zshrc" ]] && source "\$HOME/.zshrc"
[[ -f "$envrc" ]] && source "$envrc"
[[ -f "$init_script" ]] && source "$init_script"
ZSHRC
        ZDOTDIR="$_zdir" exec zsh
    elif [[ "$SHELL" == *bash* ]]; then
        exec bash --rcfile <(echo "[[ -f ~/.bashrc ]] && source ~/.bashrc; source '$envrc'; source '$init_script'")
    else
        exec "$SHELL"
    fi
fi
SCRIPT
chmod +x "${bin_dir}/setup-test"

cat > "${bin_dir}/show-test" <<'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail

# Parse args: show-test <scenario> [--checks]
scenario=""
checks_flag=""
while [[ $# -gt 0 ]]; do
    case "$1" in
