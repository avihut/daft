cat > "${bin_dir}/test-plan" <<SCRIPT
#!/usr/bin/env bash
set -euo pipefail

plans_dir="\${DAFT_WORKTREE}/test-plans"

if [[ \$# -gt 0 ]]; then
    # Explicit plan name: test-plan progressive-adoption
    plan="\${plans_dir}/\$1.md"
    if [[ ! -f "\$plan" ]]; then
        echo "Test plan not found: \$plan" >&2
        exit 1
    fi
else
    # Auto-resolve from current branch via frontmatter
    branch=\$(git -C "\$DAFT_WORKTREE" branch --show-current 2>/dev/null || true)
    if [[ -z "\$branch" ]]; then
        echo "Could not determine current branch" >&2
        exit 1
    fi
    plan=""
    for f in "\${plans_dir}"/*.md; do
        [[ -f "\$f" ]] || continue
        # Match "branch: <value>" in YAML frontmatter (between --- delimiters)
        if sed -n '/^---$/,/^---$/p' "\$f" | grep -qE "^branch:\\s*\${branch}$"; then
            plan="\$f"
            break
        fi
    done
    if [[ -z "\$plan" ]]; then
        echo "No test plan found for branch: \$branch" >&2
        if ls "\${plans_dir}"/*.md &>/dev/null; then
            echo "" >&2
            echo "Available test plans:" >&2
            for f in "\${plans_dir}"/*.md; do
                echo "  \$(basename "\${f%.md}")" >&2
            done
        fi
        exit 1
    fi
fi

XDG_CONFIG_HOME="\${DAFT_WORKTREE}/tools/nvim" \
XDG_DATA_HOME="${sandbox_dir}/config/nvim/data" \
XDG_STATE_HOME="${sandbox_dir}/config/nvim/state" \
XDG_CACHE_HOME="${sandbox_dir}/config/nvim/cache" \
NVIM_APPNAME=test-plan \
exec ${nvim_path} "\$plan"
SCRIPT
chmod +x "${bin_dir}/test-plan"

# --- Completions for helper scripts ---
cat > "${bin_dir}/completions/_manual-test" <<'ZSH_COMP'
#compdef manual-test

_manual-test() {
    local -a scenarios
    local scenarios_dir="${DAFT_WORKTREE}/tests/manual/scenarios"

    if [[ -d "$scenarios_dir" ]]; then
        local f rel
        for f in "$scenarios_dir"/**/*.yml "$scenarios_dir"/**/*.yaml(N); do
            rel="${f#$scenarios_dir/}"
            if [[ "$rel" == */* ]]; then
                # Subdirectory: exec/checkout-single.yml → exec:checkout-single
                scenarios+=("${rel%%/*}:${${rel#*/}:r}")
            else
                scenarios+=("${rel:r}")
            fi
        done
    fi

    _arguments -s \
        '--ci[Run in non-interactive mode]' \
        '--no-interactive[Run in non-interactive mode]' \
        {-v,--verbose}'[Show verbose output]' \
        '--step[Jump to a specific step number]:step number:' \
        '--loop-count[Re-run a specific step N times]:count:' \
        '--keep[Keep test environment after completion]' \
        '--list[List available scenarios and exit]' \
        '*:scenario:($scenarios)'
}
ZSH_COMP

cat > "${bin_dir}/completions/manual-test.bash" <<'BASH_COMP'
_manual_test() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    if [[ "$cur" == -* ]]; then
        COMPREPLY=($(compgen -W "--ci --no-interactive -v --verbose --step --loop-count --keep --list" -- "$cur"))
        return
    fi
    local scenarios_dir="${DAFT_WORKTREE}/tests/manual/scenarios"
    if [[ -d "$scenarios_dir" ]]; then
        local scenarios="" f rel name
        while IFS= read -r -d '' f; do
            rel="${f#$scenarios_dir/}"
            name="${rel%.yml}"
            name="${name%.yaml}"
            if [[ "$name" == */* ]]; then
                # Subdirectory: exec/checkout-single → exec:checkout-single
                name="${name%%/*}:${name#*/}"
            fi
            scenarios="$scenarios $name"
        done < <(find "$scenarios_dir" \( -name '*.yml' -o -name '*.yaml' \) -print0 2>/dev/null)
        COMPREPLY=($(compgen -W "$scenarios" -- "$cur"))
    fi
}
complete -F _manual_test manual-test
BASH_COMP

