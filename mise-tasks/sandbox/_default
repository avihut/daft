# --- Sourceable init script (completions + shell-init) ---
cat > "${bin_dir}/init" <<'LOADER'
# Initialize the sandbox shell: completions + daft shell integration.
# Usage: source init
if [[ -n "${ZSH_VERSION:-}" ]]; then
    source "${DAFT_SANDBOX_COMPLETIONS_DIR}/_manual-test"
    compdef _manual-test manual-test
    source "${DAFT_SANDBOX_COMPLETIONS_DIR}/_setup-test"
    compdef _setup-test setup-test
    source "${DAFT_SANDBOX_COMPLETIONS_DIR}/_show-test"
    compdef _show-test show-test
    source "${DAFT_SANDBOX_COMPLETIONS_DIR}/_reset-test"
    compdef _reset-test reset-test
    source "${DAFT_SANDBOX_COMPLETIONS_DIR}/_test-plan"
    compdef _test-plan test-plan
    eval "$(daft shell-init zsh)"
elif [[ -n "${BASH_VERSION:-}" ]]; then
    source "${DAFT_SANDBOX_COMPLETIONS_DIR}/manual-test.bash"
    source "${DAFT_SANDBOX_COMPLETIONS_DIR}/setup-test.bash"
    source "${DAFT_SANDBOX_COMPLETIONS_DIR}/show-test.bash"
    source "${DAFT_SANDBOX_COMPLETIONS_DIR}/reset-test.bash"
    source "${DAFT_SANDBOX_COMPLETIONS_DIR}/test-plan.bash"
    eval "$(daft shell-init bash)"
fi

# Shell function to reload the sandbox environment in the current shell
reload-sandbox() {
    local sandbox_dir="$(dirname "$(dirname "${DAFT_SANDBOX_COMPLETIONS_DIR}")")"
    source "${sandbox_dir}/.envrc"
    source "${sandbox_dir}/bin/init"
    echo "Sandbox reloaded"
}
LOADER

